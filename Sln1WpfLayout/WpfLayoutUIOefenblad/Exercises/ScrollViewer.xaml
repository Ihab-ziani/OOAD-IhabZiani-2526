<Page x:Class="WpfLayoutUIOefenblad.Exercises.ScrollViewer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfLayoutUIOefenblad.Exercises"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ScrollViewer">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Frame x:Name="fraAssignment"
               Grid.Row="0"
               Background="#eeeeee" />

        <Border Background="#F3F3F3"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                Padding="12"
                Margin="20"
                Grid.Row="1">

            <!-- ScrollViewer toegevoegd -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Background="#F3F3F3" Margin="10">

                    <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10">
                        Sectie 1
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,20">
                        Hipoteca eh desperto pintados le ni bastante se habitaba...
                    </TextBlock>

                    <Image Source="/Assignments/img/blazer01.JPG"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Left"
                           Width="80"/>

                    <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10">
                        Sectie 2
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,20">
                        Ca il abattre ennemie lisiere faisait ma melezes...
                    </TextBlock>

                    <Image Source="/Assignments/img/blazer02.JPG"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Left"
                           Width="80"/>

                    <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10">
                        Sectie 3
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,20">
                        Meinung atemzug konntet gerbers dorthin wie wer ein...
                    </TextBlock>

                    <Image Source="/Assignments/img/blazer03.JPG"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Left"
                           Width="80"/>

                </StackPanel>

            </ScrollViewer>
        </Border>
    </Grid>
</Page>