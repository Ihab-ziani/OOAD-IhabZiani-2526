<Page x:Class="WpfLayoutUIOefenblad.Exercises.NotepadApp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfLayoutUIOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="650"
      d:DesignWidth="800"
      Title="NotepadApp">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Frame x:Name="fraAssignment"
               Grid.Row="0"
               Background="#eeeeee" />

        <Border Background="White"
                BorderBrush="#6B6CB0"
                BorderThickness="1"
                Grid.Row="1"
                Margin="10"
                Width="600">

            <DockPanel>

                <!-- MENU -->
                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="_Bestand">
                        <MenuItem Header="Nieuw"/>
                        <MenuItem Header="Openen"/>
                        <Separator/>
                        <MenuItem Header="Opslaan"/>
                        <MenuItem Header="Afsluiten"/>
                    </MenuItem>

                    <MenuItem Header="_Bewerken">
                        <MenuItem Header="Knippen"/>
                        <MenuItem Header="Kopiëren"/>
                        <MenuItem Header="Plakken"/>
                    </MenuItem>
                </Menu>

                <!-- STATUSBAR -->
                <StatusBar DockPanel.Dock="Bottom">
                    <StatusBarItem>
                        <TextBlock Text="Klaar"/>
                    </StatusBarItem>
                    <StatusBarItem HorizontalAlignment="Right">
                        <TextBlock Text="Regel 1, Kolom 1"/>
                    </StatusBarItem>
                </StatusBar>

                <!-- TABCONTROL MET EDITOR -->
                <TabControl>

                    <TabItem Header="Document1.txt">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Hidden"
                                     HorizontalScrollBarVisibility="Hidden"
                                     FontFamily="Consolas"
                                     FontSize="14"/>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Document2.txt">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Hidden"
                                     HorizontalScrollBarVisibility="Hidden"
                                     FontFamily="Consolas"
                                     FontSize="14"/>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

            </DockPanel>
        </Border>
    </Grid>
</Page>